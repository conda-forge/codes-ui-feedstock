@@ -1,3 +1,22 @@
+// Windows/MSVC fixes for popen/pclose and WEXITSTATUS
+#ifdef _WIN32
+#include <stdio.h>
+
+// POSIX popen/pclose → MSVC _popen/_pclose
+#ifndef popen
+#define popen  _popen
+#endif
+#ifndef pclose
+#define pclose _pclose
+#endif
+
+// POSIX wait macros unavailable on Windows.
+// _pclose() returns exit code directly.
+#ifndef WEXITSTATUS
+#define WEXITSTATUS(x) (x)
+#endif
+
+#endif
